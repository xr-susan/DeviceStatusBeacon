@page "/dashboard"
@model DeviceStatusBeacon.Pages.DashboardModel
@{
	ViewData["Title"] = "仪表板";
	var session = Model.Overview.Session;
	var queryScope = session.Role.GetDeviceQueryScopeText();
}

@section HeadStyles {
	<link rel="stylesheet" href="~/css/pages/dashboard.css" asp-append-version="true" />
}

@section HeadModules {
	<script type="module" src="~/js/pages/dashboard.js" asp-append-version="true"></script>
}

<div class="page">
	<header class="page-header">
		<div>
			<h1 class="page-header__title">仪表板</h1>
			<p class="page-header__subtitle">查看当前账户可见的设备、日志和最近活动。</p>
		</div>
	</header>

	<section class="dashboard-overview">
		<article class="panel dashboard-account-panel">
			<div class="panel__header">
				<h2 class="panel__title">账户信息</h2>
			</div>
			<dl class="info-list">
				<div class="info-list__row">
					<dt>用户名</dt>
					<dd>@session.UserName</dd>
				</div>
				<div class="info-list__row">
					<dt>显示名称</dt>
					<dd>@(string.IsNullOrWhiteSpace(session.DisplayName) ? "未设置" : session.DisplayName)</dd>
				</div>
				<div class="info-list__row">
					<dt>角色</dt>
					<dd>@(session.Role?.ToString() ?? "未绑定角色")</dd>
				</div>
				<div class="info-list__row">
					<dt>查询范围</dt>
					<dd>@queryScope</dd>
				</div>
			</dl>
		</article>

		<article class="panel dashboard-metrics-panel">
			<div class="panel__header">
				<h2 class="panel__title">活动概览</h2>
			</div>
			<div class="dashboard-metric-grid">
				<article class="panel metric-card">
					<span class="metric-card__label">可见设备</span>
					<strong class="metric-card__value">@Model.Overview.AccessibleDeviceCount</strong>
				</article>
				<article class="panel metric-card">
					<span class="metric-card__label">启用设备</span>
					<strong class="metric-card__value">@Model.Overview.EnabledDeviceCount</strong>
				</article>
				<article class="panel metric-card">
					<span class="metric-card__label">近期活跃设备</span>
					<strong class="metric-card__value">@Model.Overview.RecentActiveDeviceCount</strong>
				</article>
				<article class="panel metric-card">
					<span class="metric-card__label">可见日志</span>
					<strong class="metric-card__value" id="dashboard-total-log-count">-</strong>
				</article>
			</div>
		</article>
	</section>

	<section class="panel">
		<div class="panel__header">
			<div>
				<h2 class="panel__title">最近活动（近 @Model.Overview.RecentActiveWindowHours 小时）</h2>
			</div>
		</div>

		<div class="dashboard-activity" id="dashboard-activity" data-activity-state="loading" data-activity-url="@Model.ActivityApiPath">
			<div class="empty-state">正在加载近期设备活动。</div>
		</div>
	</section>
</div>