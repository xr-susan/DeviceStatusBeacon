@{
	var pageTitle = ViewData["Title"] is string title ? $"{title} - 设备状态信标" : "设备状态信标";
	var hasInteractiveSession = User.HasInteractiveUserSession();
	var currentPath = Context.Request.Path;
	var publicHomeHref = Url.Page("/Index") ?? "/";
	var dashboardHref = Url.Page("/Dashboard") ?? "/dashboard";
	var devicesHref = Url.Page("/Devices/Index") ?? "/devices";
	var logsHref = Url.Page("/Logs") ?? "/logs";
	var adminHref = Url.Page("/Admin/Index") ?? "/admin";
	var loginHref = Url.Page("/Account/Login") ?? "/login";
	var homeHref = hasInteractiveSession ? dashboardHref : publicHomeHref;
	var devicesIsActive = currentPath.StartsWithSegments("/devices");
	var logsIsActive = currentPath.StartsWithSegments("/logs");
	var adminIsActive = currentPath.StartsWithSegments("/admin");
	var (_, _, currentRole) = User.GetAuthenticatedPrincipalInfo();
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>@pageTitle</title>
	<meta name="author" content="LC" />
	@RenderSection("HeadMeta", required: false)
	<link rel="icon" type="image/svg+xml" href="~/favicon.svg" asp-append-version="true" />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
	@RenderSection("HeadStyles", required: false)
	@RenderSection("HeadModulePreloads", required: false)
	<script type="module" src="~/js/site.js" asp-append-version="true"></script>
	@RenderSection("HeadModules", required: false)
</head>
<body>
	<header class="app-header">
		<div class="app-header__inner">
			<div class="app-header__start">
				<a href="@homeHref" class="app-brand">
					<img src="~/favicon.svg" asp-append-version="true" alt="DSB" class="app-brand__mark" />
					<span class="app-brand__text">设备状态信标</span>
				</a>

				<nav class="app-nav" aria-label="主导航">
					@if (hasInteractiveSession) {
						<a href="@devicesHref" class="app-nav__link @(devicesIsActive ? "app-nav__link--active" : null)">设备</a>
						<a href="@logsHref" class="app-nav__link @(logsIsActive ? "app-nav__link--active" : null)">日志</a>
						@if (currentRole.IsAdministrator()) {
							<a href="@adminHref" class="app-nav__link @(adminIsActive ? "app-nav__link--active" : null)">管理</a>
						}
					}
					@RenderSection("HeaderNavigation", required: false)
				</nav>
			</div>

			<div class="app-header__actions">
				@if (IsSectionDefined("HeaderActions")) {
					@RenderSection("HeaderActions")
				} else if (hasInteractiveSession) {
					<div class="header-user">@User.Identity?.Name</div>
					<form method="post" asp-page="/Account/Logout" class="button-form">
						<button type="submit" class="button button--header">退出登录</button>
					</form>
				} else {
					<a href="@loginHref" class="button button--header">登录</a>
				}
			</div>
		</div>
	</header>

	<div class="app-shell">
		<main class="app-main">
			@RenderBody()
		</main>
	</div>

	@RenderSection("AfterMain", required: false)
</body>
</html>